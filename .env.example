# ── PostgreSQL ─────────────────────────────────────────────────────────
POSTGRES_DB=brain_tumor
POSTGRES_USER=btuser
POSTGRES_PASSWORD=your_password_here

# ── LLM 설정 ───────────────────────────────────────────────────────────
# Groq 사용 시 (권장): https://console.groq.com 에서 발급
GROQ_API_KEY=gsk_your_groq_api_key_here
LLM_BACKEND=groq          # groq | ollama

# Ollama 사용 시 (로컬)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3:8b

# ── 경로 설정 (Docker 기준) ────────────────────────────────────────────
ML_PIPELINE_PATH=/ml_pipeline
UPLOAD_DIR=/app/uploads
CHROMA_DIR=/app/chroma_db

# ── DB URL (Docker Compose 자동 설정) ─────────────────────────────────
DATABASE_URL=postgresql+asyncpg://btuser:your_password_here@db:5432/brain_tumor
